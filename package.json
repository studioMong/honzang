{
  "name": "honzang",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "start": "HOSTNAME=0.0.0.0 node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke:prod": "node scripts/smoke-production.mjs",
    "verify:mvp": "node scripts/verify-mvp.mjs",
    "verify:deployment-config": "node scripts/verify-deployment-config.mjs",
    "verify:limits": "node scripts/verify-file-limits.mjs",
    "verify:data-sources": "tsx scripts/verify-data-sources.ts",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "verify:access-control": "node scripts/verify-access-control.mjs",
    "verify:backup-restore": "node scripts/verify-backup-restore.mjs",
    "verify:railway": "node scripts/verify-railway.mjs",
    "audit:railway": "node scripts/audit-railway-deployment.mjs",
    "verify:samples": "tsx scripts/verify-sample-csvs.ts",
    "verify:db-workflow": "tsx scripts/verify-db-workflow.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "dotenv": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "papaparse": "latest",
    "pg": "^8.21.0",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/papaparse": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
